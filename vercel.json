{
  "rewrites": [
    {
      "source": "/((?!sitemap\\.xml|robots\\.txt).*)",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    { "source": "/contacts", "destination": "/contact", "permanent": true },
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "deccanailabs.vercel.app" }],
      "destination": "https://deccanailabs.com/:path*",
      "permanent": true
    }
  ]
}
