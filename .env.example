# Local dev: /api is proxied to http://localhost:5000 by vite.config.js
VITE_API_URL=/api

# Production (Vercel): set this to your Render API URL
# VITE_API_URL=https://deccanailabs.onrender.com/api

# Official site URL — used for canonical links, sitemap, and structured data
VITE_SITE_URL=https://deccanailabs.com

# Optional: @username for Twitter Card site attribution (e.g. @deccanailabs)
VITE_TWITTER_SITE=
